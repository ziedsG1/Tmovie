# Optional on Vercel: set to your live URL (https://your-app.vercel.app)
# If unset, the app uses the request host automatically (recommended).
# Do NOT set this to http://localhost:3000 in production.
# NEXT_PUBLIC_SITE_URL=https://your-app.vercel.app

# Optional: TMDB v3 API key — improves IMDb → TMDB mapping for VidSrc / stream fallback
# Get one at https://www.themoviedb.org/settings/api
# TMDB_API_KEY=your_tmdb_v3_api_key

# IMDb metadata does not require a key.
