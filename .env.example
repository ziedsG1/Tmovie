# Optional: public site URL for HLS proxy (defaults to request host)
# NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Optional: TMDB v3 API key — improves IMDb → TMDB mapping for VidSrc / stream fallback
# Get one at https://www.themoviedb.org/settings/api
# TMDB_API_KEY=your_tmdb_v3_api_key

# IMDb metadata does not require a key.
